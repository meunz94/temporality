---
import Base from '../layouts/Base.astro';
import { Content } from '../content/notice.md';

const base = import.meta.env.BASE_URL;
const home = base;
---

<Base title="공지사항 — (Tempo)rality">
  <main class="page">
    <a class="back pixel" href={home}>← Back to the (Future)</a>
    <article class="body">
      <Content />
    </article>
  </main>
</Base>

<style>
  .page {
    max-width: 820px;
    margin: 50;
    padding: clamp(2rem, 6vw, 5rem) 1.5rem;
    min-height: 100vh;
    text-align: left;
    transform: scale(0.7);          /* 전체 뷰 기준 70% 축소 */
    transform-origin: top left;
  }
  .back {
    font-family: 'Galmuri9', monospace;
    -webkit-font-smoothing: none;
    font-size: 0.95rem;
    text-decoration: none;
    color: var(--dim);
  }
  .back:hover { color: var(--fg); }

  .body {
    font-family: var(--sans);
    font-weight: 400;
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.8;
    color: var(--fg);
    margin: 2.5rem 0 0;
  }

  /* 마크다운 렌더링 스타일 */
  .body :global(h1) {
    font-family: var(--serif);
    -webkit-font-smoothing: none;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    line-height: 1.4;
    margin: 0 0 1.5rem;
    padding-top: 3rem;
    padding-bottom: 0.6rem;
  }
  .body :global(h2) {
    font-family: var(--sans);
    font-weight: 700;
    font-size: clamp(1.2rem, 2.5vw, 1.5rem);
    margin: 2rem 0 0.8rem;
  }
  .body :global(p) { margin: 1rem 0; }
  .body :global(ul) { margin: 1rem 0; padding-left: 1.4rem; }
  .body :global(li) { margin: 0.4rem 0; }
  .body :global(strong) { font-weight: 700; }
  .body :global(a) { color: var(--fg); }
  .body :global(blockquote) {
    margin: 1.5rem 0;
    padding: 0.4rem 0 0.4rem 1rem;
    border-left: 3px solid var(--dim);
    color: var(--dim);
    font-size: 0.95em;
  }
  .body :global(code) {
    font-family: 'Galmuri9', monospace;
    -webkit-font-smoothing: none;
    background: rgba(255, 255, 255, 0.08);
    padding: 0.1em 0.3em;
    border-radius: 3px;
  }
</style>
